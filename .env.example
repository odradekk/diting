# ============================================================
# Diting MCP — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Required variables must be set for the server to start.
# ============================================================

# --- Required: LLM Configuration ---
# Two tiers: reasoning (scoring, summarization, query generation)
# and fast (evaluation). Both use OpenAI v1 compatible endpoints.
# They can point to the same provider or different ones.
LLM_REASONING_BASE_URL=https://api.openai.com/v1
LLM_REASONING_MODEL=gpt-4o
LLM_REASONING_API_KEY=sk-xxx
LLM_FAST_BASE_URL=https://api.openai.com/v1
LLM_FAST_MODEL=gpt-4o-mini
LLM_FAST_API_KEY=sk-xxx

# --- Optional: Tavily API ---
# Used as the deepest fetch fallback (Extract API) — paid, so only
# used after local fetcher and r.jina.ai both fail. Not required.
TAVILY_API_KEY=

# --- Optional: r.jina.ai Reader fallback ---
# Free markdown extraction service used as the second fetch layer
# (after curl_cffi/browser fails, before Tavily). Works on many
# Cloudflare-protected sites. A key is NOT required; supplying one
# lifts the anonymous per-IP rate limit.
# ENABLE_JINA_READER=true
# JINA_API_KEY=

# --- Optional: Archive snapshot fallback ---
# When the live URL fails, tries Wayback Machine and Archive.today
# snapshots. Only attempts static-content URLs (articles, blog posts);
# search pages, API endpoints, and feeds are skipped automatically.
# ENABLE_ARCHIVE_FALLBACK=true

# --- Optional: Stealth browser (patchright) ---
# When true, the local fetcher and Playwright-based modules (x, zhihu)
# launch patchright instead of vanilla Playwright to bypass Cloudflare /
# DataDome fingerprinting. Requires: pip install diting[stealth]
# Default is false so the base install stays light.
# ENABLE_STEALTH_BROWSER=false

# --- Search Module API Keys ---
# At least one search module should be configured
BRAVE_API_KEY=
SERP_API_KEY=
# GITHUB_TOKEN=           # GitHub personal access token (optional, lifts rate limit to 30/min)

# --- Timeouts (seconds) ---
# LLM_TIMEOUT=60          # Per LLM call timeout
# MODULE_TIMEOUT=30       # Per search module timeout
# GLOBAL_TIMEOUT=120      # Overall search pipeline timeout

# --- Search Control ---
# MAX_SEARCH_ROUNDS=3     # Maximum iterative search rounds
# ENABLE_BAIDU=true       # Enable Baidu scraping module (no API key needed)
# ENABLE_BING=true        # Enable Bing scraping module (no API key needed)
# ENABLE_BRAVE=true       # Enable Brave Search module (requires BRAVE_API_KEY)
# ENABLE_DUCKDUCKGO=true  # Enable DuckDuckGo scraping module (no API key needed)
# ENABLE_SERP=true        # Enable SERP API module (requires SERP_API_KEY)
# ENABLE_X=false          # Enable X/Twitter module (requires cookie, Playwright)
# ENABLE_ZHIHU=false      # Enable Zhihu module (requires cookie, Playwright)
# ENABLE_ARXIV=false      # Enable arXiv academic paper search (free, no key)
# ENABLE_WIKIPEDIA=false  # Enable Wikipedia search, en+zh (free, no key)
# ENABLE_STACKEXCHANGE=false  # Enable StackExchange Q&A search (free, no key)
# ENABLE_GITHUB=false     # Enable GitHub repository search (free, optional token)

# --- Cookies (for Playwright-based modules) ---
# Raw cookie header string; storage state files in config/ take priority
# X_COOKIE=
# ZHIHU_COOKIE=

# --- Filtering / Scoring ---
# SCORE_THRESHOLD=0.3      # Minimum score to keep a result (0-1)
# MIN_SNIPPET_LENGTH=30    # Minimum snippet chars to keep a result
# SCORER_BACKEND=hybrid    # hybrid | llm | reranker(legacy alias); hybrid auto-falls back to LLM if unavailable
# RERANKER_MODEL=BAAI/bge-reranker-base
# RERANKER_CACHE_DIR=      # Empty -> ~/.cache/diting/models/bge-reranker-base
# SEMANTIC_DEDUP=false     # Enable semantic deduplication via BGE embeddings
# SEMANTIC_DEDUP_THRESHOLD=0.9  # Cosine similarity above which two results are considered duplicates
# To use local reranking or semantic dedup, install the optional extra:
# pip install 'diting[rerank]'

# --- Blacklist (regex rules file) ---
# BLACKLIST_FILE=blacklist.txt          # Path to unified blacklist rules file
# AUTO_BLACKLIST=true                   # Auto-append low-scoring domains
# AUTO_BLACKLIST_THRESHOLD=0.3          # Domains with ALL results below this get blacklisted

# --- Routing Strategy ---
# Controls how the orchestrator selects search modules for each round.
#   funnel      — Smart 3-layer routing (LLM → embedding → all), cost gate,
#                 progressive evaluator-driven routing. (Default)
#   cheap_first — Free modules only in Round 1 (skips LLM routing call).
#                 Round 2+ opens up via evaluator. Minimises API costs.
#   fire_all    — All modules every round. No routing, no cost gating.
#                 Backward-compatible escape hatch.
# ROUTING_STRATEGY=funnel

# --- Misc ---
# LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
# PROMPTS_DIR=            # Custom prompts directory (overrides built-in defaults)
