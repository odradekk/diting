# diting — environment variable reference
#
# Copy this file to .env (gitignored) or export the variables in your shell.
# diting reads everything from the process environment; there is no implicit
# .env loading. If you keep a .env file, source it manually:
#
#     set -a; . ./.env; set +a; diting search "your question"
#
# All credentials are BYOK. diting never bundles, transmits, or stores keys
# anywhere outside your local environment and ~/.config/diting/config.yaml.

# ============================================================================
# LLM provider — REQUIRED (one of the two blocks below)
# ============================================================================

# --- Anthropic (native) -----------------------------------------------------
# The default LLM provider. Resolved first if both Anthropic and OpenAI keys
# are set. Cheapest viable model: Claude Haiku. Reference benchmark uses
# Claude Sonnet via this path.
#
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI / OpenAI-compatible ---------------------------------------------
# Falls back to OpenAI if no Anthropic key is set. The OPENAI_BASE_URL and
# OPENAI_MODEL overrides let you talk to any OpenAI-compatible endpoint
# (MiniMax, DeepSeek, Together, Groq, vLLM, ollama, etc.).
#
# Native OpenAI:
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4.1-mini
#
# MiniMax M2.7 HighSpeed (cheapest reasoning model — used in early benchmark runs):
# OPENAI_API_KEY=your-minimax-key
# OPENAI_BASE_URL=https://api.minimaxi.com/v1
# OPENAI_MODEL=MiniMax-M2.7-highspeed
#
# DeepSeek Chat (cheapest non-reasoning model — used in v2.0.0 reference run):
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# ============================================================================
# Search modules — OPTIONAL (each unlocks a higher-quality source)
# ============================================================================
# diting ships with eight search modules. Six are keyless (bing, duckduckgo,
# baidu, arxiv, github-anonymous, stackexchange) and run with no setup. The
# two BYOK modules below add coverage and quality. The LLM planner picks
# modules per query based on source-type need; missing keys silently disable
# the corresponding module without erroring.

# Brave Search — 2,000 free queries/month. Recommended.
# BRAVE_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SerpAPI — Google results via paid proxy. ~100 free queries/month, then paid.
# Marked CostTierExpensive in the registry; the planner deprioritises it.
# SERP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub PAT — lifts GitHub Search rate limit from 10 to 30 req/min.
# Anonymous access works, but a PAT is recommended if you query code often.
# Required scopes: public_repo (read-only).
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Fetch layer — OPTIONAL (paid last-resort fallback)
# ============================================================================
# The fetch chain has five layers (utls -> chromedp -> jina -> archive ->
# tavily). The first four are keyless. tavily is paid and only runs if
# enabled here. Use it as a paid extraction backstop for the rare URL that
# defeats every free layer.
#
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# diting-internal — OPTIONAL (advanced overrides)
# ============================================================================

# Override the config file path. Defaults to ~/.config/diting/config.yaml.
# DITING_CONFIG=/path/to/custom/diting.yaml

# Default per-query timeout for `diting search`. Accepts Go duration syntax
# (e.g. 90s, 3m, 2h). Defaults to 300s. Reasoning models that emit long
# <think> blocks may need 5+ minutes.
# DITING_SEARCH_TIMEOUT=300s

# Override the scoring config used for source ranking. Defaults to the
# built-in heuristic table. See examples/scorer.yaml for the schema.
# DITING_SCORER_CONFIG=/path/to/scorer.yaml

# ============================================================================
# Benchmark variants — OPTIONAL (only used by `diting bench run`)
# ============================================================================
# These are read by the v2-single and v2-raw benchmark variants when you want
# to drive the plan and answer phases with separate LLM clients (e.g. cheap
# DeepSeek for planning, more expensive Claude for answering, or the
# v2.0.0-reference dual-DeepSeek setup).
#
# These variables are NOT read by `diting search` — for the main CLI use the
# OPENAI_* variables above with the appropriate base URL.
#
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
