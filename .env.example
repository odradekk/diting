# ============================================================
# Super Search MCP — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# Required variables must be set for the server to start.
# ============================================================

# --- Required: LLM Configuration ---
# OpenAI v1 compatible API endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx

# --- Required: Tavily API ---
# Used for fetching page content (Extract API)
TAVILY_API_KEY=tvly-xxx

# --- Search Module API Keys ---
# At least one search module should be configured
BRAVE_API_KEY=
SERP_API_KEY=

# --- Timeouts (seconds) ---
# LLM_TIMEOUT=60          # Per LLM call timeout
# MODULE_TIMEOUT=30       # Per search module timeout
# GLOBAL_TIMEOUT=120      # Overall search pipeline timeout

# --- Search Control ---
# MAX_SEARCH_ROUNDS=3     # Maximum iterative search rounds
# ENABLE_BRAVE=true       # Enable Brave Search module
# ENABLE_SERP=true        # Enable SERP API module

# --- Filtering ---
# BLACKLIST_DOMAINS=example.com,spam.org   # Comma-separated blocked domains
# SCORE_THRESHOLD=0.3     # Minimum score to keep a result (0-1)

# --- Pre-filter (between dedup and LLM scoring) ---
# FILTER_VIDEO_DOMAINS=   # Override default video domain list (comma-separated)
# MIN_SNIPPET_LENGTH=30   # Minimum snippet chars to keep a result
# FILTER_SEARCH_PAGES=true  # Remove search engine result pages

# --- Auto-blacklist ---
# AUTO_BLACKLIST_THRESHOLD=0.3  # Domains with ALL results below this get blacklisted
# AUTO_BLACKLIST_FILE=data/auto_blacklist.json  # Persistence file path

# --- Misc ---
# LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR
# PROMPTS_DIR=            # Custom prompts directory (overrides built-in defaults)
